{
  "name": "scratch-explainer-extension",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "esbuild src/content.ts --bundle --outfile=dist/content.js --platform=browser --target=chrome120",
    "watch": "esbuild src/content.ts --bundle --outfile=dist/content.js --platform=browser --target=chrome120 --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "scratch-explainer-shared": "*"
  }
}
